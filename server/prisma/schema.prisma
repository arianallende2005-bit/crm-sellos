generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullName  String?  @map("full_name")
  role      String   @default("cliente") // 'admin' | 'cliente'
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  
  orders        Order[]
  notifications Notification[]
  historyChanges OrderHistory[]

  @@map("users")
}

model Order {
  id            Int      @id @default(autoincrement())
  clientId      Int      @map("client_id")
  productName   String   @map("product_name")
  imageUrl      String?  @map("image_url")
  currentStatus Int      @default(1) @map("current_status") // 1-5
  isArchived    Boolean  @default(false) @map("is_archived")
  archivedDate  DateTime? @map("archived_date")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  client  User           @relation(fields: [clientId], references: [id])
  history OrderHistory[]
  notifications Notification[]

  @@map("orders")
}

model OrderHistory {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  status    Int
  changedBy Int      @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")
  notes     String?

  order   Order @relation(fields: [orderId], references: [id])
  changer User  @relation(fields: [changedBy], references: [id])

  @@map("order_history")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  orderId   Int?     @map("order_id")
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@map("notifications")
}
